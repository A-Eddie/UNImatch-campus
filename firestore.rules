rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Deny everything by default ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helper functions ─────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      // NOTE: This performs a Firestore document read per call.
      // Use sparingly and only in paths that require admin access.
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function validUserData(data) {
      return data.keys().hasAll(['name', 'email', 'uni', 'dept', 'gender'])
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 80
        && data.email is string && data.email.size() <= 200
        && data.uni is string && data.uni.size() <= 120
        && data.dept is string && data.dept.size() <= 120
        && data.gender in ['man', 'woman', 'nonbinary']
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 500))
        && (!('interests' in data) || (data.interests is list && data.interests.size() <= 20));
    }

    // ── Users collection ─────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user may read a public profile
      allow read: if isSignedIn();

      // A user may create their own document on registration
      allow create: if isOwner(userId)
        && validUserData(request.resource.data)
        // Prevent self-assignment of privileged fields
        && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false)
        && (!('status' in request.resource.data) || request.resource.data.status == 'active');

      // A user may update only their own document, with field restrictions
      allow update: if isOwner(userId)
        && validUserData(request.resource.data)
        // Cannot elevate own admin flag
        && request.resource.data.isAdmin == resource.data.isAdmin
        // Cannot change own status (ban/unban is admin-only)
        && request.resource.data.status == resource.data.status
        // Cannot change own email or ID
        && request.resource.data.email == resource.data.email
        && request.resource.data.id == resource.data.id;

      // Only admins may delete user documents
      allow delete: if isAdmin();

      // Private sub-collection: only the owner can read/write
      match /private/{doc} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Swipes collection ─────────────────────────────────────────────────────
    // swipes/{swiperId}/targets/{targetId}
    match /swipes/{swiperId}/targets/{targetId} {
      allow read: if isOwner(swiperId) || isAdmin();
      allow create, update: if isOwner(swiperId)
        && request.resource.data.keys().hasAll(['direction', 'timestamp'])
        && request.resource.data.direction in ['left', 'right', 'super']
        && request.resource.data.timestamp is timestamp;
      allow delete: if isOwner(swiperId) || isAdmin();
    }

    // ── Matches collection ────────────────────────────────────────────────────
    // Matches are written only by Cloud Functions (server-side)
    // so no client writes are allowed.
    match /matches/{matchId} {
      allow read: if isSignedIn()
        && (resource.data.user1 == request.auth.uid
            || resource.data.user2 == request.auth.uid);
      allow write: if false; // Cloud Functions only
    }

    // ── Messages collection ────────────────────────────────────────────────────
    // chats/{chatId}/messages/{messageId}
    // chatId must be the two UIDs joined in sorted order: "uid1_uid2"
    match /chats/{chatId}/messages/{messageId} {
      function chatParticipants() {
        return chatId.split('_');
      }
      function isParticipant() {
        return isSignedIn() && request.auth.uid in chatParticipants();
      }

      allow read: if isParticipant();

      allow create: if isParticipant()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.timestamp is timestamp;

      // Messages are immutable once sent
      allow update, delete: if false;
    }

    // ── Reports collection ────────────────────────────────────────────────────
    match /reports/{reportId} {
      // Write-only for authenticated users; only admins can read
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasAll(['reporterId', 'reportedId', 'reason'])
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Block list ─────────────────────────────────────────────────────────────
    // blocks/{userId}/blocked/{blockedId}
    match /blocks/{userId}/blocked/{blockedId} {
      allow read, write: if isOwner(userId);
    }

    // ── Admin actions ──────────────────────────────────────────────────────────
    // Allow admins to update user status (approve/ban/unban)
    match /users/{userId} {
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'verified']);
    }

  }
}
